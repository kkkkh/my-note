// tsconfig.json
{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./docs/*"],
      // "@play/*": ["./docs/submodule/play/packages/*"],
      "/*": ["./docs/*"],

    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop":true,
    // "module":"esnext",
    // "target": "es2016"
  },
  "include": [
    "docs/**/*.ts",
    "docs/**/*.d.ts",
    "docs/**/*.vue"
  ]
}
